# ===========================================
# AI CREATIVE STUDIO - Environment Config
# ===========================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control!

# ===========================================
# ENVIRONMENT MODE
# ===========================================
# Set to 'development' for local SQLite + local file storage
# Set to 'production' for Supabase DB + Supabase storage
APP_ENV=development

# ===========================================
# GEMINI API KEY (Required)
# ===========================================
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ===========================================
# LOCAL DEVELOPMENT SETTINGS
# ===========================================
# SQLite database file path (for Prisma)
DATABASE_URL="file:./dev.db"

# Local storage path for creatives (relative to project root)
LOCAL_STORAGE_PATH=./storage/creatives

# Local development server port
LOCAL_SERVER_PORT=3001

# ===========================================
# GENERATION CONCURRENCY (Optional)
# ===========================================
# Max parallel Gemini calls when generating a batch of images.
# Default: 5 (verified safe for gemini-3-pro-image-preview, ~6x faster than serial).
# Lower this (e.g. 2-3) if you're on a constrained Gemini quota and hit 429s.
# Higher values (8-10) may help for very large batches but risk rate-limiting.
# GENERATION_CONCURRENCY=5

# ===========================================
# SUPABASE CREDENTIALS (Required for Production)
# ===========================================
# Get these from your Supabase project settings:
# Project Settings > API > Project URL & anon/public key

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ===========================================
# HOW TO USE
# ===========================================
# 
# DEVELOPMENT MODE (default):
#   1. Set APP_ENV=development
#   2. Run: npm run dev
#   3. Uses local SQLite database + local file storage
#
# PRODUCTION MODE:
#   1. Set APP_ENV=production
#   2. Fill in SUPABASE_URL and SUPABASE_ANON_KEY
#   3. Run: npm run dev:prod
#   4. Uses Supabase database + Supabase storage
#
# See DEVELOPMENT.md for more details
